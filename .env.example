# Core runtime
PORT=3000
NODE_ENV=development
SESSION_SECRET=
AUTH_MODE=optional
TRUST_PROXY=false

# Docker Compose deployment
KBNAVIGATOR_IMAGE=ghcr.io/jumby42/kbnavigator:v1.0.0
KBNAVIGATOR_PORT=3000

# Paths
KB_ROOT=./data/Knowledgebase
DATA_DIR=./data
LOGS_DIR=./data/logs
DRAFTS_DIR=./data/drafts
SESSIONS_DIR=./data/sessions
BACKUPS_DIR=./data/backups
FLAGS_FILE=./data/flags.json
VERSIONS_FILE=./data/versions.json
APPROVALS_FILE=./data/approvals.json

# Auth/security tuning
REMEMBER_ME_DAYS=7
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
BCRYPT_ROUNDS=12

# Locks/trash/logging
LOCK_TTL_MINUTES=30
LOCK_HEARTBEAT_SECONDS=120
TRASH_RETENTION_DAYS=30
LOG_RETENTION_DAYS=30


# Read/search/admin write throttles
READ_RATE_LIMIT_WINDOW_SECONDS=60
READ_RATE_LIMIT_MAX_REQUESTS=240
SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
SEARCH_RATE_LIMIT_MAX_REQUESTS=90
ADMIN_WRITE_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_WRITE_RATE_LIMIT_MAX_REQUESTS=120

# Backup runtime
BACKUP_UPLOAD_MAX_BYTES=524288000
BACKUP_AUTO_RESTART_ON_RESTORE=true
BACKUP_SCHEDULER_TICK_SECONDS=30
BACKUP_MAX_RUN_HISTORY=5000

# Approval workflow limits
APPROVALS_MAX_RESOLVED_HISTORY=2000
APPROVALS_MAX_INLINE_IMAGE_BYTES=2097152
APPROVALS_MAX_INLINE_TOTAL_BYTES=12582912
